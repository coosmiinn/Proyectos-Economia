    "import pandas as pd\n",
    "\n",
    "datos = {\n",
    "    \"pais\" : [\"España\", \"Francia\", \"Italia\", \"Alemania\"],\n",
    "    \"PIB\" : [1400, 2800, 2100, 3800],\n",
    "    \"inflacion\" : [2.5, 2.1, 2.8, 1.9]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(datos)\n",
    "\n",
    "print(df[\"PIB\"].mean())\n",
    "print(df[\"PIB\"].max())\n",
    "print(df[df[\"inflacion\"] > 2.3])"
   ]

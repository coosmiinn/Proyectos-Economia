    "import pandas as pd \n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "datos = {\n",
    "    \"pais\": [\"España\", \"Francia\", \"Italia\"],\n",
    "    \"inflacion\": [2.5, 2.1, 2.8],\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(datos)\n",
    "\n",
    "plt.bar(df[\"pais\"], df[\"inflacion\"])\n",
    "plt.show"
   ]

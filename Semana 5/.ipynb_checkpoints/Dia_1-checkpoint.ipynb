    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "datos = {\n",
    "    \"pais\" : [\"España\", \"Francia\", \"Italia\"],\n",
    "    \"PIB\" : [1400, 2800, 2100]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(datos)\n",
    "\n",
    "plt.plot(df[\"pais\"], df[\"PIB\"])\n",
    "plt.show()"
   ]

   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "datos = { \n",
    "    \"pais\": [\"Japon\", \"Corea del Sur\", \"EEUU\"],\n",
    "    \"PIB\": [3500, 4000, 2500]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(datos)\n",
    "\n",
    "plt.bar(df[\"pais\"], df[\"PIB\"])\n",
    "plt.title(\"PIB por pais\")\n",
    "plt.xlabel(\"Pais\")\n",
    "plt.ylabel(\"PIB\")\n",
    "plt.show()"
   ]
  },
